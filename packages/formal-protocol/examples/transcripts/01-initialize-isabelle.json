{
  "name": "initialize-isabelle",
  "steps": [
    {
      "kind": "request",
      "message": {
        "jsonrpc": "2.0",
        "id": 1,
        "method": "initialize",
        "params": {
          "protocolVersion": "2026-03-21",
          "clientInfo": {
            "name": "fixture-client",
            "version": "0.1.0"
          },
          "capabilities": {
            "subscriptions": true,
            "rawPayload": true
          }
        }
      }
    },
    {
      "kind": "response",
      "forMethod": "initialize",
      "message": {
        "jsonrpc": "2.0",
        "id": 1,
        "result": {
          "protocolVersion": "2026-03-21",
          "serverInfo": {
            "name": "formal-hub",
            "version": "0.1.0"
          },
          "capabilities": {
            "workspaceDiscovery": true,
            "documentSync": {
              "mode": "incremental"
            },
            "buildTargets": true,
            "queries": {
              "goals": true,
              "hover": true,
              "definition": true,
              "type": true,
              "dependencies": true,
              "diagnostics": true,
              "status": true
            },
            "probes": {
              "counterexample": true,
              "proofSearch": true,
              "replay": true,
              "premiseDeletion": true,
              "conclusionPerturbation": true,
              "consistencyCheck": false,
              "dependencySlice": true,
              "buildReplay": true
            },
            "auditSignals": {
              "trustFrontier": true,
              "rawBackendPayload": true,
              "contractPack": true
            },
            "subscriptions": {
              "progress": true,
              "diagnostics": true,
              "goals": true,
              "audit": true
            },
            "runGovernance": {
              "supports_run_jobs": true,
              "supports_cancel": true,
              "supports_kill": true,
              "supports_heartbeat_budget": false,
              "supports_progress_events": true,
              "supports_raw_backend_handles": false,
              "require_explicit_budget": true,
              "max_concurrent_runs": 4,
              "max_queued_runs": 0
            },
            "experimental": {
              "backend/isabelle/nativeExtensions": true
            }
          }
        }
      }
    }
  ]
}
