{
  "name": "rocq-local",
  "version": "0.1.0",
  "protocolVersion": "2026-03-21",
  "backendKind": "rocq",
  "languages": [
    "rocq"
  ],
  "capabilities": {
    "workspaceDiscovery": true,
    "documentSync": {
      "mode": "incremental"
    },
    "buildTargets": true,
    "queries": {
      "goals": true,
      "hover": true,
      "definition": true,
      "type": false,
      "dependencies": true,
      "diagnostics": true,
      "status": true
    },
    "probes": {
      "counterexample": false,
      "proofSearch": true,
      "replay": false,
      "premiseDeletion": false,
      "conclusionPerturbation": false,
      "consistencyCheck": false,
      "dependencySlice": true,
      "buildReplay": false
    },
    "auditSignals": {
      "trustFrontier": false,
      "rawBackendPayload": true,
      "contractPack": true
    },
    "subscriptions": {
      "progress": true,
      "diagnostics": true,
      "goals": true,
      "audit": true
    },
    "runGovernance": {
      "supports_run_jobs": true,
      "supports_cancel": true,
      "supports_kill": true,
      "supports_heartbeat_budget": false,
      "supports_progress_events": true,
      "supports_raw_backend_handles": false,
      "require_explicit_budget": true,
      "max_concurrent_runs": 4,
      "max_queued_runs": 0
    },
    "experimental": {
      "backend/rocq/nativeExtensions": true
    }
  },
  "transport": {
    "kind": "stdio"
  },
  "argv": [
    "python",
    "-m",
    "rocq_adapter"
  ]
}
